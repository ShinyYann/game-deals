#!/bin/sh

# Gradle wrapper script - generated for TrophyRoom build
# Use Flutter's built-in Gradle integration instead of custom wrapper

APP_HOME=$( cd "${0%[/\\]*}" > /dev/null && pwd -P ) || exit
APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Use JAVA_HOME if set, else java in PATH
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD=$JAVA_HOME/bin/java
else
    JAVACMD=java
fi

if ! command -v "$JAVACMD" >/dev/null 2>&1; then
    die "ERROR: JAVA_HOME is not set and no 'java' command could be found."
fi

exec "$JAVACMD" \
    -Xmx64m \
    -Xms64m \
    -Dorg.gradle.appname="$APP_BASE_NAME" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain "$@"
